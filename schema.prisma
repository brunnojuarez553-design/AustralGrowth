generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  avatarUrl   String?
  role        UserRole  @default(OWNER)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  leads       Lead[]
  activities  Activity[]
  tasks       Task[]     @relation("AssignedTasks")
  proposals   Proposal[]
  notes       Note[]
  @@index([workspaceId])
  @@index([email])
}

model Workspace {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logoUrl     String?
  currency    String    @default("USD")
  monthlyGoal Float     @default(6000)
  yearlyGoal  Float     @default(72000)
  plan        Plan      @default(STARTER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]
  leads       Lead[]
  projects    Project[]
  proposals   Proposal[]
  finances    Finance[]
  automations Automation[]
  tags        Tag[]
  pipelines   Pipeline[]
  aiInsights  AIInsight[]
  @@index([slug])
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Lead {
  id              String        @id @default(cuid())
  workspaceId     String
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedToId    String?
  assignedTo      User?         @relation(fields: [assignedToId], references: [id])
  pipelineId      String?
  pipeline        Pipeline?     @relation(fields: [pipelineId], references: [id])
  companyName     String
  contactName     String?
  email           String?
  whatsapp        String?
  instagram       String?
  website         String?
  country         String?
  city            String?
  industry        String?
  companySize     CompanySize?
  source          LeadSource    @default(MANUAL)
  stage           PipelineStage @default(DETECTED)
  priority        Priority      @default(MEDIUM)
  estimatedValue  Float?
  probability     Float?
  isHot           Boolean       @default(false)
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  closedAt        DateTime?
  lostReason      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  notes           Note[]
  activities      Activity[]
  tasks           Task[]
  proposals       Proposal[]
  tags            LeadTag[]
  project         Project?
  @@index([workspaceId])
  @@index([stage])
  @@index([assignedToId])
  @@index([priority])
  @@index([nextFollowUpAt])
  @@index([isHot])
}

model Pipeline {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String    @default("Principal")
  isDefault   Boolean   @default(false)
  leads       Lead[]
  @@index([workspaceId])
}

enum PipelineStage {
  DETECTED
  CONTACTED
  REPLIED
  MEETING
  DEMO
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadSource {
  MANUAL
  INSTAGRAM
  WHATSAPP
  EMAIL
  REFERRAL
  COLD_OUTREACH
  INBOUND
  CSV_IMPORT
  AI_DETECTED
}

enum CompanySize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String   @db.Text
  isAI      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([leadId])
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())
  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

enum ActivityType {
  STAGE_CHANGED
  NOTE_ADDED
  EMAIL_SENT
  WHATSAPP_SENT
  CALL_MADE
  MEETING_SCHEDULED
  PROPOSAL_SENT
  PROPOSAL_VIEWED
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  TASK_CREATED
  TASK_COMPLETED
  FILE_UPLOADED
  AI_INSIGHT
  AUTOMATION_TRIGGERED
}

model Task {
  id           String     @id @default(cuid())
  leadId       String?
  lead         Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?      @relation("AssignedTasks", fields: [assignedToId], references: [id])
  title        String
  description  String?    @db.Text
  status       TaskStatus @default(TODO)
  priority     Priority   @default(MEDIUM)
  dueDate      DateTime?
  completedAt  DateTime?
  parentId     String?
  parent       Task?      @relation("SubTasks", fields: [parentId], references: [id])
  subtasks     Task[]     @relation("SubTasks")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@index([leadId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

model Proposal {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  title       String
  serviceType String
  description String?        @db.Text
  amount      Float
  currency    String         @default("USD")
  validUntil  DateTime?
  status      ProposalStatus @default(DRAFT)
  plan        String?
  sections    Json?
  pdfUrl      String?
  viewedAt    DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  sentAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  @@index([workspaceId])
  @@index([leadId])
  @@index([status])
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId      String?       @unique
  lead        Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(IN_PROGRESS)
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  tasks       Task[]
  files       ProjectFile[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@index([workspaceId])
  @@index([status])
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  ON_HOLD
  CANCELLED
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  url        String
  size       Int?
  mimeType   String?
  uploadedAt DateTime @default(now())
  @@index([projectId])
}

model Finance {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        FinanceType
  category    String
  description String
  amount      Float
  currency    String      @default("USD")
  date        DateTime
  isPaid      Boolean     @default(true)
  leadId      String?
  projectId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  @@index([workspaceId])
  @@index([type])
  @@index([date])
}

enum FinanceType {
  INCOME
  EXPENSE
  ADVANCE
  PENDING
}

model Automation {
  id            String            @id @default(cuid())
  workspaceId   String
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  isActive      Boolean           @default(true)
  trigger       AutomationTrigger
  triggerConfig Json
  actions       Json
  runCount      Int               @default(0)
  lastRunAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  @@index([workspaceId])
  @@index([isActive])
}

enum AutomationTrigger {
  LEAD_STAGE_CHANGED
  LEAD_CREATED
  NO_CONTACT_DAYS
  PROPOSAL_SENT
  PROPOSAL_VIEWED
  PROPOSAL_ACCEPTED
  TASK_OVERDUE
  DEAL_WON
  DEAL_LOST
}

model Tag {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  color       String    @default("#6366F1")
  leads       LeadTag[]
  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model LeadTag {
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([leadId, tagId])
}

model AIInsight {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        InsightType
  title       String
  content     String      @db.Text
  priority    Priority    @default(MEDIUM)
  leadId      String?
  isDismissed Boolean     @default(false)
  createdAt   DateTime    @default(now())
  @@index([workspaceId])
  @@index([isDismissed])
  @@index([createdAt])
}

enum InsightType {
  HOT_LEAD
  FORGOTTEN_LEAD
  RISK_ALERT
  OPPORTUNITY
  FOLLOW_UP
  REVENUE_PROJECTION
  BOTTLENECK
  RECOMMENDATION
}
